---
import Layout from "~/layouts/Layout.astro";
import TimeLine from "~/components/TimeLine/index.astro";
import Skills from "~/components/Skills.astro";
import SubHeading from "~/components/common/SubHeading.astro";
import { Config } from "~/config";

const yearsOfExperienceString = `${Config.me.yearsOfExperience || "less than 1"}+ ${+Config.me.yearsOfExperience > 1 ? "years" : "year"}`;
---

<Layout title={`Profile | ${Config.me.name}`}>
  <main class="lg:mt-32 mt-10 mb-12 mb-20 divide-y divide-section-divider">
    <section class="pb-8">
      <h1
        class="capitalize font-medium text-3xl mb-8 md:mb-14 mt-4"
        role="heading"
      >
        Profile
      </h1>
      <em
        class="text-secondary block not-italic md:text-base text-sm font-normal leading-normal"
      >
        Hi, I am Youenn Esnault, a Data Scientist with overall {yearsOfExperienceString}
        of experience, proficient in <strong>
          Python (PySpark, Keras, TensorFlow, Scikit-Learn)</strong
        >,<strong> R</strong>,<strong> SQL</strong>,<strong>
          Node.js</strong
        >,<strong> TypeScript</strong>,<strong> Electron.js</strong>,<strong>
          MongoDB</strong
        >, <strong> Ruby</strong>,<strong> Ruby on Rails</strong>, and <strong>
          PostgreSQL</strong
        >. I completed a dual Master's program, an <strong
          area-label="Master of Science in Data Science (Honors)"
          title="Master of Science in Data Science (Honors)"
          class="font-normal">M.Sc in Data Science (Honors)</strong
        > and an <strong
          area-label="Engineering Degree in Computer Science (Honors)"
          title="Engineering Degree in Computer Science (Honors)"
          class="font-normal"> Engineering Degree in Computer Science (Honors)</strong
        > in 2023. 
        Throughout my career, I have led and worked on various team and solo projects in Data Science, Machine Learning and Deep Learning. 
        I have worked with experts from diverse sectors (health, construction, environment) and am used to translating business needs into technical solutions. 
        I love taking on challenging projects that will push me to learn and grow.
      </em>
      <div class="mt-4 w-11/12 flex items-center gap-x-2">
        <a
          href={Config.me.resumeLink}
          rel="noopener noreferrer nofollow"
          target="_blank"
          class="inline-block !font-inter font-bold text-xs bg-blue-btn text-white capitalize rounded-full md:rounded-md text-center border-2 border-blue-btn"
        >
          <button
            class="inline-block basis-2/5 md:basis-[25%] px-2 py-2.5 !font-inter font-bold text-xs bg-blue-btn text-white capitalize rounded-full md:rounded-md"
            >Download Resume</button
          >
        </a>
      </div>
    </section>
    <section class="px-0 flex flex-col gap-8 py-8">
      <SubHeading text="Experience" />
      <ul class="block list-none time-line-container h-full grid gap-4">
        {
          Config.about.workExperiences.map((workExp) => (
            <TimeLine
              type="work"
              title={workExp.title}
              years={workExp.years}
              company={workExp.company}
              contributions={workExp.contributions}
            />
          ))
        }
      </ul>
    </section>
    <section class="flex flex-col gap-8 py-8">
      <SubHeading text="Education" />
      <ul class="block list-none time-line-container h-full grid gap-4">
        {
          Config.about.educationDetails?.map((education) => (
            <TimeLine
              type="education"
              title={education.title}
              years={education.years}
              institute={education.institute}
              address={education.address}
            />
          ))
        }
      </ul>
    </section>
    <section class="py-8">
      <Skills />
    </section>
