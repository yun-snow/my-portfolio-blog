---
import Layout from "../../layouts/Layout.astro";
import { getCollection, type CollectionEntry } from "astro:content";
import {Config} from "~/config.ts";

export async function getStaticPaths() {
  const posts = (await getCollection("posts")).sort(
    (a, b) =>
      new Date(a.data.publishedOn).getTime() -
      new Date(b.data.publishedOn).getTime()
  );

  return posts.map((post, index) => ({
    params: { slug: post.slug },
    props: {
      post,
      prevPost: index > 0 ? posts[index - 1] : null,
      nextPost: index < posts.length - 1 ? posts[index + 1] : null,
    },
  }));
}

interface Props {
  post: CollectionEntry<"posts">;
  prevPost: CollectionEntry<"posts"> | null;
  nextPost: CollectionEntry<"posts"> | null;
}
const { post, prevPost, nextPost } = Astro.props;
const formattedPublishedAtDate = new Date(post.data.publishedOn).toLocaleDateString(
  "en-us",
  {
    year: "numeric",
    month: "long",
    day: "numeric",
  }
);           
const { Content } = await post.render();
---

<Layout
  title={post.data.title}
  description={post.data.summary}
  blog_author={post.data.author}
  blog_publishedOn={formattedPublishedAtDate}

  keywords={post.data.keywords}
  og_title={post.data.title}
  og_description={post.data.summary}
  og_type="article"
  og_image={`${Config.website}/og/blogs/${post.slug}.png`}
>
  <main class="lg:my-32 mt-10 mb-12">
    <article class="pt-8 pb-14 md:px-2 md:pt-6 min-h-screen blog-wrapper prose lg:m-0 mx-auto flex w-full lg:max-w-full max-w-prose flex-col">
      <h1 class="mb-0 text-3xl md:text-4xl max-w-[620px]" area-label={`Title of the blog is "${post.data.title}"`} role="heading">
        {post.data.title}
      </h1>
      <p class="mt-8 mb-0 p-0 text-sm mb-1 tracking-wide">
        Author: <a class="no-underline font-medium" href='/' rel="noopener noreferrer nofollow" area-label={`Author name is ${post.data.author}`} role="contentinfo">{post.data.author}</span>
      </p>
      <p class="mt-0 mb-2 p-0 pb-3 text-sm border-b border-section-divider">
        Published on: <span class="font-medium" area-label={`This article was published on ${formattedPublishedAtDate}`} role="contentinfo">{formattedPublishedAtDate}</span>
      </p>
      
      <div class="blog-content">
        <Content />
      </div>
      
      <nav class="flex gap-4 mt-16 pt-8 border-t border-section-divider not-prose">
        {prevPost && (
          <a
            href={`/blogs/${prevPost.slug}`}
            class="flex-1 flex flex-col gap-1 px-4 py-3 border border-dashed border-gray-300 dark:border-gray-700 rounded hover:border-gray-500 dark:hover:border-primary transition-colors"
          >
            <span class="text-xs text-secondary">← Previous</span>
            <span class="text-sm font-medium text-primary line-clamp-2">{prevPost.data.title}</span>
          </a>
        )}
        {!prevPost && <div class="flex-1" />}
        {nextPost && (
          <a
            href={`/blogs/${nextPost.slug}`}
            class="flex-1 flex flex-col gap-1 px-4 py-3 border border-dashed border-gray-300 dark:border-gray-700 rounded hover:border-gray-500 dark:hover:border-primary transition-colors text-right"
          >
            <span class="text-xs text-secondary">Next →</span>
            <span class="text-sm font-medium text-primary line-clamp-2">{nextPost.data.title}</span>
          </a>
        )}
        {!nextPost && <div class="flex-1" />}
      </nav>


    </article>
   </main>
</Layout>
